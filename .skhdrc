# ==============================================================================
# SKHD CONFIGURATION - Optimized for Yabai v7.0+
# ==============================================================================

# --- Window Focus (Vim keys) ---
alt + shift - h : yabai -m window --focus west
alt + shift - j : yabai -m window --focus south
alt + shift - k : yabai -m window --focus north
alt + shift - l : yabai -m window --focus east
alt + shift - o : yabai -m window --focus next || yabai -m window --focus first

# --- Window Movement (Swap & Warp) ---
# Swap: Exchange places with another window
ctrl + alt - h : yabai -m window --swap west
ctrl + alt - j : yabai -m window --swap south
ctrl + alt - k : yabai -m window --swap north
ctrl + alt - l : yabai -m window --swap east

# Warp: Push window into a new position (re-tiles the rest)
ctrl + shift - h : yabai -m window --warp west
ctrl + shift - l : yabai -m window --warp east

# --- Layout Controls ---
alt - f     : yabai -m window --toggle float --grid 4:4:1:1:2:2
alt - z     : yabai -m window --toggle zoom-fullscreen
alt - e     : yabai -m space --layout bsp
alt - s     : yabai -m space --layout monocle
alt - space : yabai -m space --rotate 90
alt - 0     : yabai -m space --balance

# --- Resizing (Step-based) ---
# Modern approach: resize handles edges more intuitively
alt + cmd - h : yabai -m window --resize left:-50:0;  yabai -m window --resize right:-50:0
alt + cmd - j : yabai -m window --resize bottom:0:50; yabai -m window --resize top:0:50
alt + cmd - k : yabai -m window --resize top:0:-50;    yabai -m window --resize bottom:0:-50
alt + cmd - l : yabai -m window --resize right:50:0;  yabai -m window --resize left:50:0

# --- Space & Display Management ---
# Focus spaces
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4

# Send window to space and follow focus
shift + alt - 1 : yabai -m window --space 1; yabai -m space --focus 1
shift + alt - 2 : yabai -m window --space 2; yabai -m space --focus 2
shift + alt - 3 : yabai -m window --space 3; yabai -m space --focus 3

# Focus Display (Monitor)
ctrl + alt - z : yabai -m display --focus prev
ctrl + alt - x : yabai -m display --focus next

# --- Utility ---
# Close focused window
alt + shift - q : yabai -m window --close

# Restart Yabai (Useful since you are running it manually)
ctrl + alt + cmd - r : pkill -9 yabai; yabai & disown